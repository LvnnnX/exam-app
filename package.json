{
  "name": "exam-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "test:rls": "playwright test tests/rls.spec.ts --config=playwright.rls.config.ts",
    "audit:high": "npm audit --audit-level=high",
    "security:check": "npm run build && npm run test:api-security && npm run test:rls && npm run audit:high",
    "test:api-security": "playwright test tests/api-security.spec.ts --config=playwright.rls.config.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.103.3",
    "@tanstack/react-query": "5.100.10",
    "@tiptap/extension-code-block-lowlight": "3.22.4",
    "@tiptap/extension-image": "3.22.4",
    "@tiptap/extension-mathematics": "3.22.4",
    "@tiptap/extension-table": "3.22.4",
    "@tiptap/extension-table-cell": "3.22.4",
    "@tiptap/extension-table-header": "3.22.4",
    "@tiptap/extension-table-row": "3.22.4",
    "@tiptap/extension-text-align": "3.22.4",
    "@tiptap/pm": "3.22.4",
    "@tiptap/react": "3.22.4",
    "@tiptap/starter-kit": "3.22.4",
    "@types/crypto-js": "4.2.2",
    "canvas-confetti": "1.9.4",
    "clsx": "2.1.1",
    "crypto-js": "4.2.0",
    "dompurify": "3.4.0",
    "exceljs": "^4.4.0",
    "framer-motion": "12.38.0",
    "highlight.js": "11.11.1",
    "katex": "0.16.45",
    "lowlight": "3.3.0",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/canvas-confetti": "1.9.0",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "app/actions/**/*.{ts,tsx}": [
      "node scripts/check-no-console-log.mjs"
    ],
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  }
}
